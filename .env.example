# Dobot Robot Configuration
# Copy this to .env and customize for your setup

# Robot IP address
# Wired: 192.168.5.1 (default)
# Wireless: 192.168.1.6
ROBOT_IP=192.168.5.1

# Robot model: cr3, cr5, cr7, cr10, cr12, cr16, cr20
ROBOT_TYPE=cr5

# SpaceMouse pendant device passthrough:
# GID of the host's 'input' group — the container needs membership in this
# group to read /dev/input/event* (where the Bluetooth SpaceMouse shows up).
# Discover it on your host with:
#   getent group input | cut -d: -f3
# Fedora / Ubuntu default: 104.
INPUT_GID=104
